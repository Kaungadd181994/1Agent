SUPABASE_PUBLISHABLE_KEY="sb_publishable_mL-JnUiFJ6lTemkH894shA_22F56rWd"
SUPABASE_SECRET_KEY="sb_secret_4eVzuxnYh64E9RrXJPPWsw_zMleDTVi"
SUPABASE_JWKS_URL="https://sepiucqrayucucrcwsgw.supabase.co/auth/v1/.well-known/jwks.json"

